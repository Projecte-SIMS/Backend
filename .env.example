# Example environment file for local development
APP_NAME=ProjectSims
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=project_sims
DB_USERNAME=project_user
DB_PASSWORD=supersecret

# pgAdmin settings for local access
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Optional: change these if you map different host ports
PGADMIN_PORT=8080
