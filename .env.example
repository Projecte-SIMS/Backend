# Example environment file for local development
# Archivo de entorno de ejemplo para SIMS Backend
# Última actualización: 2026-02-23T15:54:21.878Z

# Nombre de la aplicación
APP_NAME=ProjectSims

# Entorno de ejecución (local, production, etc)
APP_ENV=local

# Clave de aplicación Laravel (rellenar en entorno real)
APP_KEY=

# Depuración (true/false)
APP_DEBUG=true

# URL base de la app
APP_URL=http://localhost:8000

# Canal de logs
LOG_CHANNEL=stack

# Configuración de base de datos PostgreSQL
DB_CONNECTION=pgsql
DB_DATABASE=project_sims
DB_HOST=db
DB_PORT=5432
DB_USERNAME=project_user
DB_PASSWORD=

# MongoDB Atlas (rellenar en entorno real, no incluir credenciales aquí)
MONGODB_URI=
MONGODB_DATABASE=cluster-iot

# Configuración de pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=8080

# Chatbot Configuration
OPEN_WEBUI_API_KEY=
OPEN_WEBUI_BASE_URL=api-ia.daw2.iesmontsia.org:3000/api
OPEN_WEBUI_MODEL=llm-per-a-alumnat