# Example environment file for local development
# Archivo de entorno de ejemplo para SIMS Backend
# Última actualización: 2026-03-02

# ==========================================
# CONFIGURACIÓN BÁSICA
# ==========================================

# Nombre de la aplicación
APP_NAME=ProjectSims

# Entorno de ejecución (local, staging, production)
APP_ENV=local

# Clave de aplicación Laravel (generar con: php artisan key:generate)
APP_KEY=

# IMPORTANTE: Siempre false en producción para no exponer errores
# Depuración (true para desarrollo, false para producción)
APP_DEBUG=true

# URL base de la app
APP_URL=http://localhost:8000

# Canal de logs
LOG_CHANNEL=stack

# ==========================================
# BASE DE DATOS POSTGRESQL
# ==========================================
DB_CONNECTION=pgsql
DB_DATABASE=project_sims
DB_HOST=db
DB_PORT=5432
DB_USERNAME=project_user
DB_PASSWORD=

# ==========================================
# MONGODB ATLAS (Telemetría IoT)
# ==========================================
# IMPORTANTE: No incluir credenciales reales aquí
MONGODB_URI=
MONGODB_DATABASE=cluster-iot

# ==========================================
# PGADMIN (Solo desarrollo)
# ==========================================
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=8080

# ==========================================
# CHATBOT / IA
# ==========================================
OPEN_WEBUI_API_KEY=
OPEN_WEBUI_BASE_URL=api-ia.daw2.iesmontsia.org:3000/api
OPEN_WEBUI_MODEL=llm-per-a-alumnat

# ==========================================
# MICROSERVICIO IOT (FastAPI)
# ==========================================
# URL del microservicio IoT (mismo servidor o red local)
IOT_MICROSERVICE_URL=http://localhost:8001
# API Key para autenticar comandos (debe coincidir con el microservicio)
IOT_API_KEY=MACMECMIC
# Timeout en segundos para peticiones al microservicio
IOT_TIMEOUT=10

# ==========================================
# RATE LIMITING (Valores por defecto en código)
# ==========================================
# LOGIN_RATE_LIMIT=5 (5 intentos por minuto)
# API_RATE_LIMIT=60 (60 peticiones por minuto)
# CHATBOT_RATE_LIMIT=20 (20 consultas por minuto)

# ==========================================
# MULTI-TENANCY (Gestión central de tenants)
# ==========================================
# Credenciales del super admin para gestionar tenants
# IMPORTANTE: Cambiar en producción
CENTRAL_ADMIN_EMAIL=superadmin@sims.com
CENTRAL_ADMIN_PASSWORD=