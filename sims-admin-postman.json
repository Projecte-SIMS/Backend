{
  "info": {
    "name": "SIMS Backend Admin Endpoints",
    "_postman_id": "sims-backend-admin-collection",
    "description": "Colección para verificar todos los endpoints admin del backend SIMS.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "http://localhost:8000/api/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@example.com\",\"password\":\"adminpassword\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.environment.set('token', jsonData.token);",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "    pm.variables.set('token', jsonData.token);",
                  "    pm.test('Token guardado correctamente', function() { pm.expect(jsonData.token).to.not.be.empty; });",
                  "} else {",
                  "    pm.test('No se recibió token', function() { pm.expect(false).to.be.true; });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {"name": "List Users", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/users", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Create User", "request": {"method": "POST", "url": "http://localhost:8000/api/admin/users", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\":\"Test User\",\"email\":\"test@example.com\",\"password\":\"123456\",\"role_id\":1}"}}},
        {"name": "View User", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/users/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Edit User", "request": {"method": "PUT", "url": "http://localhost:8000/api/admin/users/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\":\"Updated User\"}"}}},
        {"name": "Delete User", "request": {"method": "DELETE", "url": "http://localhost:8000/api/admin/users/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}}
      ]
    },
    {
      "name": "Roles",
      "item": [
        {"name": "List Roles", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/roles", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Create Role", "request": {"method": "POST", "url": "http://localhost:8000/api/admin/roles", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\":\"TestRole\",\"description\":\"Role for testing\"}"}}},
        {"name": "View Role", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/roles/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Edit Role", "request": {"method": "PUT", "url": "http://localhost:8000/api/admin/roles/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"description\":\"Updated description\"}"}}},
        {"name": "Delete Role", "request": {"method": "DELETE", "url": "http://localhost:8000/api/admin/roles/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}}
      ]
    },
    {
      "name": "Permissions",
