        {"name": "List Permissions", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/permissions", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Create Permission", "request": {"method": "POST", "url": "http://localhost:8000/api/admin/permissions", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\":\"can.edit.vehicles\",\"description\":\"Edit vehicles\"}"}}},
        {"name": "Edit Permission", "request": {"method": "PUT", "url": "http://localhost:8000/api/admin/permissions/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"description\":\"Updated permission\"}"}}},
        {"name": "Delete Permission", "request": {"method": "DELETE", "url": "http://localhost:8000/api/admin/permissions/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}}
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {"name": "List Vehicles", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/vehicles", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Create Vehicle", "request": {"method": "POST", "url": "http://localhost:8000/api/admin/vehicles", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"license_plate\":\"1234ABC\",\"brand\":\"Toyota\",\"model\":\"Corolla\",\"active\":true}"}}},
        {"name": "View Vehicle", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/vehicles/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Edit Vehicle", "request": {"method": "PUT", "url": "http://localhost:8000/api/admin/vehicles/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"brand\":\"UpdatedBrand\"}"}}},
        {"name": "Delete Vehicle", "request": {"method": "DELETE", "url": "http://localhost:8000/api/admin/vehicles/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Vehicles Map", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/vehicles/map", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}}
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {"name": "List Tickets", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/tickets", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Create Ticket", "request": {"method": "POST", "url": "http://localhost:8000/api/admin/tickets", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"title\":\"Test Ticket\",\"description\":\"Ticket description\"}"}}},
        {"name": "View Ticket", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/tickets/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Edit Ticket", "request": {"method": "PUT", "url": "http://localhost:8000/api/admin/tickets/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"description\":\"Updated description\"}"}}},
        {"name": "Delete Ticket", "request": {"method": "DELETE", "url": "http://localhost:8000/api/admin/tickets/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Add Message to Ticket", "request": {"method": "POST", "url": "http://localhost:8000/api/admin/tickets/1/messages", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"message\":\"Test message\"}"}}}
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {"name": "List Reservations", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/reservations", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Create Reservation", "request": {"method": "POST", "url": "http://localhost:8000/api/admin/reservations", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"vehicle_id\":1,\"user_id\":1,\"start_date\":\"2026-02-24T18:00:00Z\",\"end_date\":\"2026-02-24T20:00:00Z\"}"}}},
        {"name": "View Reservation", "request": {"method": "GET", "url": "http://localhost:8000/api/admin/reservations/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Edit Reservation", "request": {"method": "PUT", "url": "http://localhost:8000/api/admin/reservations/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"end_date\":\"2026-02-24T21:00:00Z\"}"}}},
        {"name": "Delete Reservation", "request": {"method": "DELETE", "url": "http://localhost:8000/api/admin/reservations/1", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}},
        {"name": "Force Finish Reservation", "request": {"method": "POST", "url": "http://localhost:8000/api/admin/reservations/1/force-finish", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}}
      ]
    }
  ]
}
